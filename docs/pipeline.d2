# Jetson BSP Repair Agent - pipeline
# Render: d2 --layout elk docs/pipeline.d2 docs/pipeline.svg
direction: down

classes: {
  llm:   { style: { fill: "#e3f2fd"; stroke: "#1976d2"; stroke-width: 2; border-radius: 8 } }
  det:   { style: { fill: "#f5f7f8"; stroke: "#90a4ae"; stroke-width: 2; border-radius: 8 } }
  human: { style: { fill: "#fff8e1"; stroke: "#f9a825"; stroke-width: 2; border-radius: 8 } }
  pub:   { style: { fill: "#e8f5e9"; stroke: "#388e3c"; stroke-width: 2; border-radius: 8 } }
  dec:   { shape: diamond; style: { fill: "#fff3e0"; stroke: "#ef6c00"; stroke-width: 2 } }
  term:  { shape: circle;  style: { fill: "#cfd8dc"; stroke: "#607d8b"; stroke-width: 2 } }
}

start: START { class: term }
end: "END\n(report.md)" { class: term }

trigger: "Trigger\nissue + logs (Actor=init-run · cronjob planned)" {
  shape: page
  style: { fill: "#fff8e1"; stroke: "#f9a825"; stroke-width: 2 }
}

graph: "LangGraph Repair Graph" {
  style: { fill: "#fafafa"; stroke: "#bdbdbd"; stroke-dash: 4; border-radius: 12 }

  classify: "classify_error\n\nin:  issue, logs, known_error_patterns.yaml\nout: bug_type, error_signatures, suspected_areas" { class: det }
  select:   "select_skills  (LLM)\n\nin:  classification, skill catalog metadata\nout: selected_skills (<=3)  ·  fallback: patterns.yaml" { class: llm }
  load:     "load_skill\n\nin:  selected_skills, skills/\nout: skill_text (full SKILL.md of selected)" { class: det }
  inspect:  "inspect_repo\n\nin:  repo_path, keywords\nout: repo_inspection.md (rg search + safe read)" { class: det }
  patch:    "patch_agent  (LLM)\n\nin:  issue, skill_text, repo_inspection, retry_context\nout: unified diff  |  NO_PATCH" { class: llm }
  d_patch:  "diff?" { class: dec }
  validate: "validate_patch\n\nin:  diff_text\nproc: normalize + git apply --check (NOT applied)\nout: patch.md, changed_files, status=generated" { class: det }
  d_valid:  "apply --check ok?" { class: dec }
  review:   "code_review_agent  (LLM, independent)\n\nin:  issue, skill names, repo_inspection, diff, policy, retry\nout: {decision, confidence, findings, required_changes}\n      fail-safe -> needs_human" { class: llm }
  d_review: "review decision?" { class: dec }
  human:    "human_review  (LangGraph interrupt)\n\nin:  patch.md, code_review.md\nout: approve  |  reject + feedback" { class: human }
  d_human:  "human?" { class: dec }
  nopatch:  "write_no_patch\n\nin:  no_patch_reason\nout: no_patch.md  ->  next attempt | report" { class: det }
  d_nopatch:"retries left?" { class: dec }
  apply:    "apply_patch\n\nin:  patch.md (canonical diff)\nproc: git apply to working tree\nout: status=applied, stage=target_ready" { class: det }
  publish:  "publish  (NEW · ADR-0002 · opt-in, default OFF)\n\nin:  applied tree, git remote/branch\nout: commit + push bsp-agent/<run_id>\n      stage=published | publish_failed" { class: pub }
}

post: "Post-approval  (CLI + human-owned, outside the graph)" {
  style: { fill: "#fafafa"; stroke: "#bdbdbd"; stroke-dash: 4; border-radius: 12 }

  buildflash: "Human build / flash\n\nin:  approved / published source\nout: flashed Jetson (git server -> build -> flash)" {
    shape: page
    style: { fill: "#f5f5f5"; stroke: "#9e9e9e" }
  }
  regtarget: "register-target\n\nin:  ssh_target, git_ref (human-declared)\nout: TargetInfo bound to run" { class: det }
  runtests:  "run-tests  (validation)\n\nin:  tests/validation/<script>\nproc: upload + SSH run\nout: exit code (authoritative)" { class: det }
  d_val:     "exit == 0?" { class: dec }
  report:    "report\n\nin:  run state + artifacts\nout: report.md" { class: det }
}

# ---- main flow ----
start -> trigger -> graph.classify -> graph.select -> graph.load -> graph.inspect -> graph.patch -> graph.d_patch
graph.d_patch -> graph.validate: diff
graph.d_patch -> graph.nopatch: NO_PATCH
graph.validate -> graph.d_valid
graph.d_valid -> graph.review: "valid (not applied)"
graph.d_valid -> graph.nopatch: invalid
graph.review -> graph.d_review

# ***** retry loop: review fail -> back to patch agent *****
graph.d_review -> graph.classify: "reject (retries left) -> new attempt" {
  style: { stroke: "#d32f2f"; stroke-width: 3 }
}
graph.d_review -> graph.human: "pass / needs_human / reject-exhausted\n(human approval always required)"

graph.human -> graph.d_human
graph.d_human -> graph.apply: approve
graph.d_human -> graph.classify: "reject + feedback -> new attempt" {
  style: { stroke: "#d32f2f"; stroke-width: 3 }
}
graph.d_human -> end: "reject exhausted"

graph.nopatch -> graph.d_nopatch
graph.d_nopatch -> graph.classify: "yes -> new attempt" {
  style: { stroke: "#d32f2f"; stroke-width: 3 }
}
graph.d_nopatch -> end: exhausted

graph.apply -> graph.publish
graph.publish -> post.buildflash

# ---- post-approval ----
post.buildflash -> post.regtarget -> post.runtests -> post.d_val
post.d_val -> post.report: success
post.d_val -> graph.classify: "fail -> re-inspect (new attempt)" {
  style: { stroke: "#d32f2f"; stroke-width: 3 }
}
post.report -> end
