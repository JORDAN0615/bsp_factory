-			netdev_mc_count(dev), pdata->num_mac_addr_regs);
-
-		l2_filter->oper_mode = (OSI_OPER_EN_PERFECT |
-					OSI_OPER_ADDR_UPDATE |
-					OSI_OPER_DIS_PROMISC |
-					OSI_OPER_DIS_ALLMULTI);
-		netdev_for_each_mc_addr(ha, dev) {
