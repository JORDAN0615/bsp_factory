-	pp_params.flags = PP_FLAG_DMA_MAP;
-	pp_params.pool_size = pool_size;
-	num_pages = DIV_ROUND_UP(osi_dma->rx_buf_len, PAGE_SIZE);
-	pp_params.order = ilog2(roundup_pow_of_two(num_pages));
