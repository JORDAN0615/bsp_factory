-	}
-#endif /* !OSI_STRIPPED_LIB */
-	if (netdev_mc_count(dev) > (pdata->num_mac_addr_regs - 1)) {
-		/* switch to PROMISCUOUS mode */
-		l2_filter->oper_mode = (OSI_OPER_DIS_PERFECT |
-					OSI_OPER_EN_PROMISC |
