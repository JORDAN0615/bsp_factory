-
-	pdata->page_pool[chan] = page_pool_create(&pp_params);
-	if (IS_ERR(pdata->page_pool[chan])) {
-		ret = PTR_ERR(pdata->page_pool[chan]);
-		pdata->page_pool[chan] = NULL;
-		return ret;
-	}
-
