-	struct ether_priv_data *pdata = netdev_priv(ndev);
-
-	if (!pdata->clks_enable) {
-		dev_err(pdata->dev,
-			"%s:No clks available, skipping PHY read\n", __func__);
-		return -ENODEV;
-	}
-
-	return osi_read_phy_reg(pdata->osi_core, (unsigned int)phyaddr,
-				(unsigned int)phyreg);
