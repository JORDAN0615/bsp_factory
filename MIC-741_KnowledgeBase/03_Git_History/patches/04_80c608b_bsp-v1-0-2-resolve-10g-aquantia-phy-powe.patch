-/**
- * @brief Initialize the PHY
- *
- * Algorithm: 1) Resets the PHY. 2) Connect to the phy described in the device tree.
- *
- * @param[in] dev: Network device data.
- *
- * @note MAC needs to be out of reset.
- *
- * @retval 0 on success
- * @retval "negative value" on failure.
- */
-static int ether_phy_init(struct net_device *dev)
-{
-	struct ether_priv_data *pdata = netdev_priv(dev);
-	struct phy_device *phydev = NULL;
-
-	pdata->oldlink = 0;
-	pdata->speed = SPEED_UNKNOWN;
-	pdata->oldduplex = SPEED_UNKNOWN;
-
-	if (pdata->phy_node != NULL) {
-		phydev = of_phy_connect(dev, pdata->phy_node,
-					&ether_adjust_link, 0,
-					pdata->interface);
-	}
-
-	if (phydev == NULL) {
-		dev_err(pdata->dev, "failed to connect PHY\n");
-		return -ENODEV;
-	}
-
-	if ((pdata->phy_node == NULL) && phydev->phy_id == 0U) {
-		phy_disconnect(phydev);
-		return -ENODEV;
-	}
-
-	/* Skip the device resume via mdio bus */
-	phydev->mac_managed_pm = true;
-	pdata->phydev = phydev;
-
-	/* ADV Custom: Initialize LEDs for 10G/MGBE PHYs */
-	if (pdata->phydev) {
-		dev_info(pdata->dev, "[ADV] Initializing AQR113C LED at PHY Addr %d\n",
-				phydev->addr);
-
-		msleep(500);
-
-		phy_write_mmd(phydev, 0x1e, 0xc430, 0xc0ef); // LED 0: Link/Activity
-		phy_write_mmd(phydev, 0x1e, 0xc431, 0x0080); // LED 1: 10G Speed Only
-		phy_write_mmd(phydev, 0x1e, 0xc432, 0xc040); // LED 2: Transmit
-	}
-
-	return 0;
-}
