+# t264.conf.common: common configurations for "thor platforms"
+
+# Sourced by bash script.
+# shellcheck shell=bash
+# Disable unused variable check. Most of these variables are used in an outer
+# script that sources this file.
+# shellcheck disable=SC2034,SC2154
+
+# Common values and/or defaults across T264 SoC:
+#
+
+source "nv_public_common_board.conf"
+
+process_chip_sku_version()
+{
+	local chip_sku="${1}";
+	local chip_minor_revision_id="${2}";
+	local bootrom_revision_id="${3}";
+	local ramcode="${4}";
+	local fuselevel="${5}";
+	local board_FAB="${6}";
+	declare -A bpmp_fw_binary;
+
+	# shellcheck disable=SC2001
+	bpmp_fw_binary['00']=$(echo "$BPFFILE" | sed -e 's/.*bpmp_t264-\([A-Za-z0-9-]*\)_.*/\1/');
+	bpmp_fw_binary['A3']="TA1080SA-A1";
+	bpmp_fw_binary['A0']="TA1090SA-A1";
+	bpmp_fw_binary['E0']="TE1090M-A1";
+	bpmp_fw_binary['E2']="TE1070M-A1";
+
+	chip_sku="${chip_sku:-${DEFAULT_CHIP_SKU}}"
+
+	if [[ "${chip_sku}" =~ ":" ]]; then
+		chip_SKU=$(echo "${chip_sku}" | awk -F ":" '{print $4}');
+	fi;
+
+	# shellcheck disable=SC2001
+	BPFFILE=$(echo "${BPFFILE}" | sed "s|TA1.*-A1|${bpmp_fw_binary[${chip_SKU}]}|");
+	# shellcheck disable=SC2001
+	BPFFILE=$(echo "${BPFFILE}" | sed "s|TE1.*-A1|${bpmp_fw_binary[${chip_SKU}]}|");
+
+	echo "Chip SKU(${chip_sku}) ramcode(${ramcode}) fuselevel(${fuselevel}) board_FAB(${board_FAB})"
+}
+process_board_version()
+{
+	local board_id="${1}";
+	local board_version="${2}";
+	local board_sku="${3}";
+	local board_revision="${4}";
+	local chiprev="${5}";
+	local platform="${7}";
+	local bootdev="${8}";
+
+	echo "Board ID(${board_id}) version(${board_version}) sku(${board_sku}) revision(${board_revision}) Platform ID($platform) Board Boot Device($bootdev)"
+}
+
+# shellcheck disable=SC2120
+set_uefi_bins() {
+	UEFI_IMAGE="${1:-uefi_t26x_general}"
+	UEFIBL="${UEFI_IMAGE}.bin"
+	TBCFILE="bootloader/uefi_bins/${UEFI_IMAGE}.bin"
+}
+
+# T264 specific internal config
+NV_INTERNAL_T264_BOARD_CONF="nv_internal_t264_board.conf"
+
+# Default fuse level
+if [ -f "${NV_INTERNAL_T264_BOARD_CONF}" ]; then
+	DFLT_FUSELEVEL="fuselevel_production"
+	source "${NV_INTERNAL_T264_BOARD_CONF}"
+fi
+
+CHIPID=0x26;
+# Overlay dts file for L4T UEFI
+OVERLAY_DTB_FILE="L4TConfiguration.dtbo,tegra264-ftpm.dtbo,T264SetFmpImageTypeGuid.dtbo";
+
+#Using UTC earlycon and console
+# Kernel command line when booting the device
+CMDLINE_ADD="mminit_loglevel=4 earlycon=tegra_utc,mmio32,0xc5a0000 console=ttyUTC0,115200 clk_ignore_unused firmware_class.path=/etc/firmware fbcon=map:0 efi=runtime audit_backlog_limit=8192"
+# The name of the folder under bootloader/ folder to get the partition table layout and BCT dts file
+target_board="generic";
+# Minimum size of the rootfs partition
+ROOTFSSIZE=55GiB;
+# UEFI and CPU Bootloader variables
+set_uefi_bins
+# Mb2 bootloader binary name
+BOOTLOADER="bootloader/mb2_t264.bin";
+# Trusted OS binary
+TOSFILE="";
+# Arm Trusted Firmware binary
+ATFFW="bootloader/bl31_t264.fip"
+# Encrypted Key Blob binary
+EKSFILE="bootloader/eks_t264.img";
+# Platform security controller - bootloader 1 binary
+PSCBL1FILE="bootloader/psc_bl1_t264_prod.bin";
+# Hardware-protected security environment - bootloader 1 binary
+HPSEBL1FILE="bootloader/hpse_bl1_t264_prod.bin";
+# StrongBox bootloader 1 binary
+SBBL1FILE="bootloader/sb_bl1_t264_prod.bin";
+# Hardware-protected security environment - firmware
+HPSEFW="bootloader/hpsefw_t264_prod.bin";
+# StrongBox firmware
+SBFW="bootloader/sbfw_t264_prod.bin";
+# Platform security controller - firmware
+PSCFW="bootloader/pscfw_t264_prod.bin";
+# Hardware-protected security environment - raw binary
+HPSERAW="bootloader/hpseraw_t264_prod.bin";
+# StrongBox raw binary
+SBRAW="bootloader/sbraw_t264_prod.bin";
+# Trusted OS firmware
+TSECFW="bootloader/tsec_t264_prod.bin";
+# Secure Partition Manager for ATF
+HAFNIUM_FW="bootloader/hafnium_t264.fip";
+# Nvdec firmware
+NVHOSTNVDEC="";
+# Display controller firmware
+DCE="bootloader/display-t264-dce.bin";
+# Camera Engine RCE1-FW binary.
+RCE1FW="bootloader/nv-rce1-t264.bin";
+# MB1 bootloader binary
+MB1FILE="bootloader/mb1_t264_prod.bin";
+# MB2 applet file. should be removed and replaced with APPLET
+SOSFILE="bootloader/applet_t264.bin";
+# MB2 bootloader binary
+MB2BLFILE="bootloader/mb2_t264.bin";
+# XML file to list binaries for mb2 applet
+READINFOFILE="readinfo_t264_min_prod.xml";
+# Camera RCE-FW binary
+CAMERAFW="bootloader/camera-rtcpu-t264-rce.img";
+# Generic suppported fuse xml file
+EMCFUSE="fuse_t264.xml";
+# MB2 applet file. Should be used instead of SOSFILE in the future
+APPLET="";
+#  Always-On (AON) Audio Digital Signal Processor (ADSP) Firmware
+AON_ADSPFW="bootloader/aon-fw_t264.bin";
+#  Always-On (AON) Audio Digital Signal Processor (ADSP) Firmware
+ADSP0FW="bootloader/adsp0-fw_t264.bin";
