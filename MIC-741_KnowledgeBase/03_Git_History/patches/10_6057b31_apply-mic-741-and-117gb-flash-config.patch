-	txesc_reg = (dfs << MTT_TXESC_TBDS_SHIFT) & MTT_TXESC_TBDS_MASK;
-
-	ret = ttcan_write32_check(ttcan, ADR_MTTCAN_TXESC, txesc_reg,
