-	if (ttcan_protected(cccr_reg))
-		return -EPERM;
-	if (enable)
-		cccr_reg |= MTT_CCCR_MON_MASK;
-	else
-		cccr_reg &= ~MTT_CCCR_MON_MASK;
-	return ttcan_write32_check(ttcan, ADR_MTTCAN_CCCR,
-				   cccr_reg, MTTCAN_CCCR_MSK);
