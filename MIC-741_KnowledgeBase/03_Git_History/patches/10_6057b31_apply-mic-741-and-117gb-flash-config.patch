-		pr_debug("0x%x\n", ttcan_get_std_id_filter(ttcan, fltr_idx));
-	}
-
-	switch (msi) {
-	default:
-		pr_debug("High Priority Interrupt received, no mesg\n");
-		return 0;
-	case 1:
-		pr_info("High Priority FIFO Mesg lost\n");
-		return 0;
-	case 2:
-		read_addr = ttcan->mram_cfg[MRAM_RXF0].off +
