-		pr_err("%s: Timeout cccr = 0x%x\n", __func__, cccr_reg);
-		return -ETIMEDOUT;
-	}
-
-	return ttcan_write32_check(ttcan, ADR_MTTCAN_TEST,
-				   test_reg, MTTCAN_TEST_MSK);
