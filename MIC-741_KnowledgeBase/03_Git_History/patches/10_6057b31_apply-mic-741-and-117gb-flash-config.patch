-	if (ttcan->tx_config.flags & 0x1)
-		txbc_reg |= MTT_TXBC_TFQM_MASK;	/* Queue mode */
-	else
-		txbc_reg &= ~(MTT_TXBC_TFQM_MASK);	/* FIFO mode */
