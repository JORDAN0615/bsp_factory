-
-	cccr_reg = ttcan_read32(ttcan, ADR_MTTCAN_CCCR);
-
-	if ((cccr_reg & MTT_CCCR_INIT_MASK) == 0) {
-		/* Controller not yet initialized */
-		cccr_reg |= 1;
-
-		ttcan_write32(ttcan, ADR_MTTCAN_CCCR, cccr_reg);
