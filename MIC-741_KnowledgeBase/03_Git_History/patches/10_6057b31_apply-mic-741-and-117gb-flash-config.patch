-
-int ttcan_set_xidam(struct ttcan_controller *ttcan, u32 regval)
-{
-	int ret = 0;
-	ret = ttcan_write32_check(ttcan, ADR_MTTCAN_XIDAM, regval,
-			MTTCAN_XIDAM_MSK);
-	if (ret)
-		pr_err("%s: unable to set XIDAM register\n", __func__);
