@@ -69,6 +69,11 @@ OVERLAY_DTB_FILE+=",tegra264-p4071-0000+p3834-xxxx-dynamic.dtbo";
 # If the carrier board is designed without an EEPROM
 SKIP_EEPROM_CHECK=1
 
+# === ODMDATA: PCIe / UPHY overrides ===
+# NOTE: only the LAST active ODMDATA line takes effect (shell reassignment).
+#       To enable several at once, merge the tokens into ONE comma-separated line.
+# Enable PCIe-C3 x2 RP (UPHY0 lane6-7) for 2nd NVMe
+ODMDATA="uphy0-config-6,pcie@3_status=okay";
 # Uncomment below line to enable C4 RP controller in SRIS mode
 #ODMDATA="pcie@4_clk-scheme=1"
 # Uncomment below line to enable C4 controller in Endpoint SRIS mode.
