-bsp_som=T5000
+# SoM selection: defaults to T5000, override with `make bsp_som=T4000`; maps to source/config/som/<som>.mk
+bsp_som ?= T5000
+include source/config/som/$(shell echo $(bsp_som) | tr A-Z a-z).mk
 bsp_jetpack=7.2
 bsp_jetpack_step=
 bsp_version=V1.0.0
