-static void tegra_pinctrl_clear_parked_bits(struct tegra_pmx *pmx)
-{
-	int i = 0;
-	const struct tegra_pingroup *g;
-	u32 val;
-
-	for (i = 0; i < pmx->soc->ngroups; ++i) {
-		g = &pmx->soc->groups[i];
-		if (g->parked_bitmask > 0) {
-			unsigned int bank, reg;
