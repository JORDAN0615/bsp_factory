-static const char *strip_prefix(const char *s)
-{
-	const char *comma = strchr(s, ',');
-	if (!comma)
-		return s;
-
-	return comma + 1;
-}
-
-static void tegra_pinconf_group_dbg_show(struct pinctrl_dev *pctldev,
-					 struct seq_file *s, unsigned group)
-{
-	struct tegra_pmx *pmx = pinctrl_dev_get_drvdata(pctldev);
-	const struct tegra_pingroup *g;
-	int i, ret;
-	s8 bank, bit, width;
-	s32 reg;
-	u32 val;
-	struct resource mem_res;
-	const struct pinctrl_ops *pctlops = pctldev->desc->pctlops;
-	const char *gname = pctlops->get_group_name(pctldev, group);
-
-	of_address_to_resource(pmx->dev->of_node, 0, &mem_res);
-	g = &pmx->soc->groups[group];
-
-	for (i = 0; i < ARRAY_SIZE(cfg_params); i++) {
-		ret = tegra_pinconf_reg(pmx, g, cfg_params[i].param, false,
-					&bank, &reg, &bit, &width);
-		if (ret < 0)
-			continue;
-
-		val = pmx_readl(pmx, bank, reg);
-		val >>= bit;
-		val &= (1 << width) - 1;
-
-		seq_printf(s, "\n\tpin=%s addr=0x%llx bank=0x%x reg=0x%x width=%d bit=%d %s=%u",
-				gname, mem_res.start + reg, bank, reg, width, bit,
-				strip_prefix(cfg_params[i].property), val);
-	}
-
-	if (g->mux_reg >= 0) {
-		/* read pinmux function and dump to seq_file */
-		val = pmx_readl(pmx, g->mux_bank, g->mux_reg);
-		val = g->funcs[(val >> g->mux_bit) & 0x3];
-
-		seq_printf(s, "\n\tpin=%s addr=0x%llx bank=0x%x reg=0x%x width=%d bit=%d function=%s", 
-				gname, mem_res.start + reg, bank, reg, width, bit,
-				pmx->functions[val].name);
-	}
-}
