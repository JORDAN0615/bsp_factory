LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen3.5-coder-32b
# LLM request timeout (seconds) and SDK-level retry count for every LLM call.
LLM_TIMEOUT_SEC=180
LLM_MAX_RETRIES=2
# On a transient LLM failure, extra in-node retries before pausing for a human,
# and the delay (seconds) between those retries.
LLM_FAILURE_NODE_RETRIES=1
LLM_FAILURE_RETRY_DELAY_SEC=60
REACT_EVIDENCE_ENABLED=false
PATCH_AGENT_AGENTIC=false
EVIDENCE_RECURSION_LIMIT=12
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=jetson-bsp-agent
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
AUTO_PUSH_ENABLED=false
GIT_REMOTE=origin
BSP_BASE_BRANCH=
GITLAB_WEBHOOK_TOKEN=replace-with-webhook-token
GITLAB_TOKEN=replace-with-a-token-that-can-comment
GITLAB_API_URL=https://gitlab.com/api/v4
BSP_REPO_PATH=/path/to/your/bsp-repo
