LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen3.5-coder-32b
# LLM request timeout (seconds) and SDK-level retry count for every LLM call.
LLM_TIMEOUT_SEC=180
LLM_MAX_RETRIES=2
# On a transient LLM failure, extra in-node retries before pausing for a human,
# and the delay (seconds) between those retries.
LLM_FAILURE_NODE_RETRIES=1
LLM_FAILURE_RETRY_DELAY_SEC=60
REACT_EVIDENCE_ENABLED=false
PATCH_AGENT_AGENTIC=false
# Experimental Deep Agents path: replaces inspect_repo + patch_agent when enabled.
DEEP_AGENT_ENABLED=false
# Read-only evidence agent round budget.
EVIDENCE_RECURSION_LIMIT=12
# Patch agent edits one location at a time, so it needs a higher round budget
# than the evidence agent (otherwise multi-file/multi-hunk patches stop short).
PATCH_AGENT_RECURSION_LIMIT=40
# Deep Agent includes planning, read-only delegation, repo exploration, and staged edits.
DEEP_AGENT_RECURSION_LIMIT=60
# MIC-741 case-based knowledge retrieval (PostgreSQL); default off.
MIC741_KNOWLEDGE_ENABLED=false
# Local dev default matches docker-compose.yml; replace <password> with your own.
MIC741_KNOWLEDGE_DB_URL=postgresql://bsp_agent:<password>@localhost:55433/bsp_agent
MIC741_KNOWLEDGE_SOURCE_DIR=RAG_DOCS/MIC-741_KnowledgeBase
MIC741_KNOWLEDGE_QUERY_LIMIT=10
# Per-case budget for complete injected patch hunks; hunks are never cut mid-content.
MIC741_KNOWLEDGE_HUNK_BUDGET_CHARS=16000
# LLM re-ranks the FTS recall set down to the most relevant repair cases.
MIC741_RERANK_ENABLED=true
MIC741_RERANK_TOP_K=3
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=jetson-bsp-agent
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
AUTO_PUSH_ENABLED=false
GIT_REMOTE=origin
BSP_BASE_BRANCH=
GITLAB_WEBHOOK_TOKEN=replace-with-webhook-token
GITLAB_TOKEN=replace-with-a-token-that-can-comment
GITLAB_API_URL=https://gitlab.com/api/v4
BSP_REPO_PATH=/path/to/your/bsp-repo
